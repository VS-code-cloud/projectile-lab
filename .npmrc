# postprocessing@6.39.1 (the latest) declares a `three` peer of ">= 0.168.0 < 0.185.0",
# which lags our three@0.185.0 (required by @react-three/fiber/drei). The dep tree is
# valid at runtime — the whole test suite + build pass — so we relax npm's strict peer
# resolution here. This is required for `npm install` on Vercel (which otherwise fails
# with ERESOLVE). Revisit once postprocessing widens its three peer range to include 0.185.
legacy-peer-deps=true
