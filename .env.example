# Copy to .env and fill in your Firebase web app config values.
# Find these in: Firebase Console > Project settings > General > "Your apps"
# (SDK setup and configuration), or run:
#   npx -y firebase-tools@latest apps:sdkconfig web
#
# LOCAL DEV: copy this file to `.env` and fill in the values below.
# VERCEL: add each VITE_* key below in Vercel > Project > Settings >
# Environment Variables (Production + Preview). These are public client config
# (safe to expose); no AI API key is needed because the app uses Firebase AI
# Logic. Redeploy after changing env vars so the new values are baked into the
# build.
#
# Required for the app to boot (used by src/firebase/config.ts):
VITE_FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000

# Optional — only needed if you use these features (referenced by firebase-config.json):
VITE_FIREBASE_PROJECT_NUMBER=000000000000
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_FIREBASE_REALTIME_DATABASE_INSTANCE_URI=your-project-id-default-rtdb
VITE_FIREBASE_REALTIME_DATABASE_URL=https://your-project-id-default-rtdb.firebaseio.com
VITE_FIREBASE_LOCATION_ID=us-central1
VITE_FIREBASE_RECAPTCHA_SITE_KEY=6LXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# OpenAI (GPT) — SERVER-SIDE SECRET. Do NOT prefix with VITE_ (that would expose
# it in the public client bundle). Used only by api/generate-practice.ts.
# VERCEL: add OPENAI_API_KEY (and optionally OPENAI_MODEL) in
# Vercel > Project > Settings > Environment Variables, NOT as a VITE_ var.
# LOCAL: put it in `.env` and run `vercel dev` so the /api function executes
# (plain `npm run dev` will not serve /api).
OPENAI_API_KEY=sk-REPLACE_WITH_YOUR_OPENAI_KEY
OPENAI_MODEL=gpt-4o-mini
