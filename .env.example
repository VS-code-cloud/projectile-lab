# Copy to .env and fill in your Firebase web app config values.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=sample-auth-domain.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=sample-project-id
VITE_FIREBASE_STORAGE_BUCKET=sample-storage-bucket.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=sample-messaging-sender-id
VITE_FIREBASE_APP_ID=sample-app-id
